# Database
DATABASE_URL="postgresql://flowboard:flowboard@localhost:5432/flowboard?schema=public"

# Auth (generate with: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-32-char-random-string"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# CORS (comma-separated list for production)
CORS_ORIGINS="http://localhost:3000"

# Pusher (real-time sync) — leave empty to disable realtime
# Server-side
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap3"
# Client-side (must mirror PUSHER_KEY / PUSHER_CLUSTER)
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap3"
